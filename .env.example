# ============================================================
# 先别买 · 环境变量配置示例
# 复制本文件为 .env 并填写真实值
# ============================================================

# ─── 数据库（必填）───────────────────────────────────────────
# Neon PostgreSQL 连接字符串
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host.neon.tech:5432/dbname?sslmode=require"

# ─── AI 服务（按需填写）──────────────────────────────────────
# DeepSeek API Key（用于商品综合分析，必填以启用 AI 分析功能）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY="sk-..."

# DeepSeek API Base URL（可选，默认 https://api.deepseek.com）
# DEEPSEEK_BASE_URL="https://api.deepseek.com"

# 阿里云通义千问 VL API Key（用于图片识别商品，可选）
# 获取地址：https://dashscope.aliyuncs.com/
QWEN_API_KEY="sk-..."

# 通义千问 Base URL（可选，默认已内置）
# QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Tavily Search API Key（用于搜索商品评价和价格，可选）
# 获取地址：https://tavily.com/
TAVILY_API_KEY="tvly-..."

# ─── Next.js（通常无需修改）──────────────────────────────────
# NODE_ENV 由部署平台自动设置，本地开发时无需手动填写
# NODE_ENV="production"
